<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.ProductManufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="$(var.UpgradeCode)"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="RdpShieldProductIcon" SourceFile="$(sys.SOURCEFILEDIR)..\assets\RdpShield.ico" />
    <Property Id="ARPPRODUCTICON" Value="RdpShieldProductIcon" />
    <Property Id="INSTALLDESKTOPSHORTCUT" Value="1" />
    <Property Id="INSTALLSTARTMENUSHORTCUT" Value="1" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLROOT" Name="RdpShield">
        <Directory Id="SERVICEINSTALLDIR" Name="Service" />
        <Directory Id="MANAGERINSTALLDIR" Name="Manager" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="RdpStartMenuDir" Name="RdpShield" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATADIR" Name="RdpShield" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="RdpShield" Level="1">
      <ComponentGroupRef Id="ServicePayload" />
      <ComponentGroupRef Id="ManagerPayload" />
      <ComponentRef Id="ServiceExecutableComponent" />
      <ComponentRef Id="DesktopShortcutComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DataDirComponent" />
    </Feature>

    <Component Id="ServiceExecutableComponent" Directory="SERVICEINSTALLDIR" Guid="*">
      <File Id="ServiceExecutableFile" Source="$(var.ServiceSourceDir)\RdpShield.Service.exe" KeyPath="yes" />
      <ServiceInstall
        Id="RdpShieldServiceInstaller"
        Name="RdpShield"
        DisplayName="RdpShield Service"
        Description="RdpShield background protection service."
        Start="auto"
        Type="ownProcess"
        ErrorControl="normal"
        Account="LocalSystem"
        Vital="yes" />
      <ServiceControl
        Id="RdpShieldServiceControl"
        Name="RdpShield"
        Start="install"
        Stop="both"
        Remove="uninstall"
        Wait="yes" />
    </Component>

    <Component Id="DesktopShortcutComponent" Directory="DesktopFolder" Guid="*" Condition="INSTALLDESKTOPSHORTCUT = 1">
      <Shortcut
        Id="DesktopManagerShortcut"
        Name="RdpShield Manager"
        Description="Open RdpShield Manager"
        Target="[MANAGERINSTALLDIR]RdpShield.Manager.exe"
        WorkingDirectory="MANAGERINSTALLDIR"
        Icon="RdpShieldProductIcon" />
      <RegistryValue Root="HKCU"
                     Key="Software\RdpShield\Shortcuts"
                     Name="Desktop"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="StartMenuShortcutComponent" Directory="RdpStartMenuDir" Guid="*" Condition="INSTALLSTARTMENUSHORTCUT = 1">
      <Shortcut
        Id="StartMenuManagerShortcut"
        Name="RdpShield Manager"
        Description="Open RdpShield Manager"
        Target="[MANAGERINSTALLDIR]RdpShield.Manager.exe"
        WorkingDirectory="MANAGERINSTALLDIR"
        Icon="RdpShieldProductIcon" />
      <RemoveFolder Id="RemoveRdpStartMenuFolder" Directory="RdpStartMenuDir" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\RdpShield\Shortcuts"
                     Name="StartMenu"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Data directory seed. Service will create settings/db files on first start. -->
    <Component Id="DataDirComponent" Directory="DATADIR" Guid="*">
      <CreateFolder />
      <RegistryValue Root="HKLM"
                     Key="Software\RdpShield"
                     Name="DataDir"
                     Type="string"
                     Value="[DATADIR]"
                     KeyPath="yes" />
    </Component>
  </Package>
</Wix>
