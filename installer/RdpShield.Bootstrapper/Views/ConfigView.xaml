<UserControl
  x:Class="Bootstrapper.Views.ConfigView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:vm="clr-namespace:Bootstrapper.ViewModels"
  xmlns:util="clr-namespace:Bootstrapper.ViewModels.Util"
  mc:Ignorable="d" 
  d:DesignWidth="450"
  d:DataContext="{d:DesignInstance {x:Type vm:ConfigViewModel}}"
  Background="Transparent"
  >

  <StackPanel Width="500">
    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" FontSize="14" Text="{Binding IntroText}" />
    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Text="{Binding DetailsText}" />

    <StackPanel Visibility="{Binding ShowPrerequisites, Converter={util:BooleanVisibilityConverter}}">
      <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Required runtime components" FontWeight="SemiBold" Margin="0,0,0,8" />
          <CheckBox
            Margin="0,0,0,8"
            IsChecked="{Binding InstallDotNetDesktopRuntime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Content=".NET Desktop Runtime 10 x64" />
          <TextBlock
            Margin="24,-4,0,8"
            Foreground="#2E7D32"
            Visibility="{Binding IsDotNetDesktopRuntimeInstalled, Converter={util:BooleanVisibilityConverter}}"
            Text="Already installed on this machine." />

          <CheckBox
            IsChecked="{Binding InstallWindowsAppRuntime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Content="Windows App Runtime 1.8 x64" />
          <TextBlock
            Margin="24,4,0,0"
            Foreground="#2E7D32"
            Visibility="{Binding IsWindowsAppRuntimeInstalled, Converter={util:BooleanVisibilityConverter}}"
            Text="Already installed on this machine." />
        </StackPanel>
      </Border>

      <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="10">
        <StackPanel>
          <TextBlock Text="Shortcuts" FontWeight="SemiBold" Margin="0,0,0,8" />
          <CheckBox
            Margin="0,0,0,8"
            IsChecked="{Binding InstallDesktopShortcut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Content="Create desktop shortcut (RdpShield Manager)" />

          <CheckBox
            IsChecked="{Binding InstallStartMenuShortcut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Content="Create Start Menu shortcut (RdpShield Manager)" />
        </StackPanel>
      </Border>
    </StackPanel>
  </StackPanel>

</UserControl>
