<Window
    x:Class="RdpShield.Manager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:RdpShield.Manager.Views"
    Title="RdpShield Manager">

    <NavigationView x:Name="Nav"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Left"
                    OpenPaneLength="220"
                    CompactPaneLength="72">
        <NavigationView.MenuItemContainerStyle>
            <Style TargetType="NavigationViewItem">
                <Setter Property="MinHeight" Value="58" />
            </Style>
        </NavigationView.MenuItemContainerStyle>

        <NavigationView.Resources>
            <Style x:Key="NavMenuContentPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="NavMenuLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="12,0,0,0" />
            </Style>
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="dashboard">
                <NavigationViewItem.Content>
                    <StackPanel Style="{StaticResource NavMenuContentPanelStyle}">
                        <Image Source="ms-appx:///Assets/dashboard.png" Width="45" Height="45" />
                        <TextBlock Text="Dashboard" Style="{StaticResource NavMenuLabelStyle}" />
                    </StackPanel>
                </NavigationViewItem.Content>
            </NavigationViewItem>
            <NavigationViewItem Tag="allowlist">
                <NavigationViewItem.Content>
                    <StackPanel Style="{StaticResource NavMenuContentPanelStyle}">
                        <Image Source="ms-appx:///Assets/allowlist.png" Width="45" Height="45" />
                        <TextBlock Text="Allowlist" Style="{StaticResource NavMenuLabelStyle}" />
                    </StackPanel>
                </NavigationViewItem.Content>
            </NavigationViewItem>
            <NavigationViewItem Tag="bans">
                <NavigationViewItem.Content>
                    <StackPanel Style="{StaticResource NavMenuContentPanelStyle}">
                        <Image Source="ms-appx:///Assets/bans.png" Width="45" Height="45" />
                        <TextBlock Text="Bans" Style="{StaticResource NavMenuLabelStyle}" />
                    </StackPanel>
                </NavigationViewItem.Content>
            </NavigationViewItem>
            <NavigationViewItem Tag="activity">
                <NavigationViewItem.Content>
                    <StackPanel Style="{StaticResource NavMenuContentPanelStyle}">
                        <Image Source="ms-appx:///Assets/activity.png" Width="45" Height="45" />
                        <TextBlock Text="Activity" Style="{StaticResource NavMenuLabelStyle}" />
                    </StackPanel>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Tag="settings">
                <NavigationViewItem.Content>
                    <StackPanel Style="{StaticResource NavMenuContentPanelStyle}">
                        <Image Source="ms-appx:///Assets/settings.png" Width="45" Height="45" />
                        <TextBlock Text="Settings" Style="{StaticResource NavMenuLabelStyle}" />
                    </StackPanel>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
