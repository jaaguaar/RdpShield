<Page
    x:Name="RootPage"
    x:Class="RdpShield.Manager.Views.BansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RdpShield.Manager.ViewModels">

    <Page.DataContext>
        <vm:BansViewModel/>
    </Page.DataContext>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Bans" Style="{StaticResource PageTitleText}" />

            <TextBox Grid.Column="1"
                     PlaceholderText="Search (ip / reason)..."
                     Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding Error}" Style="{StaticResource ErrorText}" />

        <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource CardBorder}">
            <StackPanel Spacing="10">
                <TextBlock Text="Manual block" Style="{StaticResource SectionTitleText}" Margin="0"/>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBox PlaceholderText="IP address"
                             Text="{Binding NewBlockIp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Column="1"
                             PlaceholderText="Reason (optional)"
                             Text="{Binding NewBlockReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="2"
                            Content="Block IP"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding BlockIpCommand}" />
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource TableHeaderGrid}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="IP" Style="{StaticResource TableHeaderText}"/>
            <TextBlock Grid.Column="1" Text="Reason" Style="{StaticResource TableHeaderText}"/>
            <TextBlock Grid.Column="2" Text="Expires" Style="{StaticResource TableHeaderText}"/>
            <TextBlock Grid.Column="3" Text="Action" Style="{StaticResource TableHeaderText}"/>
        </Grid>

        <ListView x:Name="BansList"
                  Grid.Row="4"
                  Margin="0,6,0,0"
                  ItemsSource="{Binding ActiveBans}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Ip}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding Reason}" TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Column="2"
                                   Style="{StaticResource MutedText}"
                                   Text="{Binding ExpiresUtc, Converter={StaticResource LocalDtFmt}, ConverterParameter='dd-MMM-yy HH:mm:ss'}"/>

                        <Button Grid.Column="3"
                                Content="Unban"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ElementName=RootPage, Path=DataContext.UnbanCommand}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <ProgressRing Width="16"
                                  Height="16"
                                  IsActive="{Binding IsLoadingMore}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource MutedText}"
                               Text="{Binding BansFooterText}" />
                </StackPanel>
            </ListView.Footer>
        </ListView>

    </Grid>
</Page>
