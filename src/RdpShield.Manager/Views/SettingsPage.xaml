<Page
    x:Name="RootPage"
    x:Class="RdpShield.Manager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RdpShield.Manager.ViewModels"
    xmlns:conv="using:RdpShield.Manager.Converters">

    <Page.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StrToVis"/>
    </Page.Resources>

    <Page.DataContext>
		<vm:SettingsViewModel/>
	</Page.DataContext>

	<StackPanel Padding="16" Spacing="12">

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<TextBlock Text="Settings" Style="{StaticResource PageTitleText}" />

			<ProgressRing Grid.Column="1" Width="18" Height="18" IsActive="{Binding IsLoading}" />
		</Grid>

		<TextBlock Text="{Binding Error}" Style="{StaticResource ErrorText}" />
        
        <Border Style="{StaticResource SuccessBannerBorder}"
                Visibility="{Binding Status, Converter={StaticResource StrToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="OK" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Status}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorder}">
			<StackPanel Spacing="12">

				<TextBlock Text="Ban logic" Style="{StaticResource SectionTitleText}" Margin="0"/>

				<Grid ColumnSpacing="12" RowSpacing="10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="220"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<TextBlock Text="Attempts threshold" Grid.Row="0" Grid.Column="0" Style="{StaticResource MutedText}"/>
                    <Grid Grid.Row="0" Grid.Column="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="-"
                                Style="{StaticResource SubtleButton}"
                                Click="OnDecreaseAttemptsThresholdClick"/>
                        <NumberBox Grid.Column="1"
                                   Value="{Binding AttemptsThreshold, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Hidden"
                                   SmallChange="1"
                                   Minimum="1"
                                   Maximum="50"/>
                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource SubtleButton}"
                                Click="OnIncreaseAttemptsThresholdClick"/>
                    </Grid>

					<TextBlock Text="Failed-attempt window (seconds)" Grid.Row="1" Grid.Column="0" Style="{StaticResource MutedText}"/>
                    <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="-"
                                Style="{StaticResource SubtleButton}"
                                Click="OnDecreaseWindowSecondsClick"/>
                        <NumberBox Grid.Column="1"
                                   Value="{Binding WindowSeconds, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Hidden"
                                   SmallChange="10"
                                   Minimum="10"
                                   Maximum="3600"/>
                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource SubtleButton}"
                                Click="OnIncreaseWindowSecondsClick"/>
                    </Grid>

					<TextBlock Text="Ban duration (minutes)" Grid.Row="2" Grid.Column="0" Style="{StaticResource MutedText}"/>
                    <Grid Grid.Row="2" Grid.Column="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="-"
                                Style="{StaticResource SubtleButton}"
                                Click="OnDecreaseBanMinutesClick"/>
                        <NumberBox Grid.Column="1"
                                   Value="{Binding BanMinutes, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Hidden"
                                   SmallChange="1"
                                   Minimum="1"
                                   Maximum="10080"/>
                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource SubtleButton}"
                                Click="OnIncreaseBanMinutesClick"/>
                    </Grid>
				</Grid>

				<TextBlock Text="Firewall" Style="{StaticResource SectionTitleText}" Margin="0,8,0,0"/>
				<ToggleSwitch Header="Enable firewall rule changes"
                              IsOn="{Binding EnableFirewall, Mode=TwoWay}" />

				<TextBlock Style="{StaticResource MutedText}"
                           Text="Changes apply immediately (on next event). Service restart is not required." />

				<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
					<Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SaveButton}"
                            Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>

					<Button Content="Save"
                            IsEnabled="False"
                            Style="{StaticResource SubtleButton}"
                            Visibility="{Binding IsDirty, Converter={StaticResource InvBoolToVis}}"/>

				</StackPanel>

			</StackPanel>
		</Border>

	</StackPanel>
</Page>
