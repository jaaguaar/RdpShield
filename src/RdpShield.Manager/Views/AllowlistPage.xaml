<Page
    x:Name="RootPage"
    x:Class="RdpShield.Manager.Views.AllowlistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RdpShield.Manager.ViewModels">

	<Page.DataContext>
		<vm:AllowlistViewModel/>
	</Page.DataContext>

	<Grid Padding="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="360" />
			</Grid.ColumnDefinitions>

			<TextBlock Text="Allowlist" Style="{StaticResource PageTitleText}" />

			<TextBox Grid.Column="1"
                     PlaceholderText="Search (entry / comment)..."
                     Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
		</Grid>

		<TextBlock Grid.Row="1" Margin="0,12,0,0" Text="{Binding Error}" Style="{StaticResource ErrorText}" />

		<Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource CardBorder}">
			<StackPanel Spacing="10">
				<TextBlock Text="Add / Update entry" Style="{StaticResource SectionTitleText}" Margin="0"/>

				<Grid ColumnSpacing="10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="260"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="120"/>
					</Grid.ColumnDefinitions>

					<TextBox PlaceholderText="Entry (IP or CIDR)"
                             Text="{Binding NewEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

					<TextBox Grid.Column="1"
                             PlaceholderText="Comment (optional)"
                             Text="{Binding NewComment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

					<Button Grid.Column="2"
                            Content="Add"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddOrUpdateCommand}" />
				</Grid>
			</StackPanel>
		</Border>

		<Grid Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource TableHeaderGrid}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="260"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="120"/>
			</Grid.ColumnDefinitions>

			<TextBlock Text="Entry" Style="{StaticResource TableHeaderText}" />
			<TextBlock Grid.Column="1" Text="Comment" Style="{StaticResource TableHeaderText}" />
			<TextBlock Grid.Column="2" Text="Action" Style="{StaticResource TableHeaderText}" />
		</Grid>

		<ListView x:Name="AllowlistList"
                  Grid.Row="4"
                  Margin="0,6,0,0"
                  ItemsSource="{Binding Items}">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Grid Style="{StaticResource RowGrid}">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="260"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
						</Grid.ColumnDefinitions>

						<TextBlock Text="{Binding Entry}" FontWeight="SemiBold"/>
						<TextBlock Grid.Column="1" Text="{Binding Comment}" TextTrimming="CharacterEllipsis" />

						<Button Grid.Column="2"
                                Content="Remove"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ElementName=RootPage, Path=DataContext.RemoveCommand}"
                                CommandParameter="{Binding}" />
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
            <ListView.Footer>
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,8">
                    <ProgressRing Width="16"
                                  Height="16"
                                  IsActive="{Binding IsLoadingMore}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource MutedText}"
                               Text="{Binding AllowlistFooterText}" />
                </StackPanel>
            </ListView.Footer>
		</ListView>

	</Grid>
</Page>
