<Page
    x:Class="RdpShield.Manager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RdpShield.Manager.ViewModels"
    xmlns:conv="using:RdpShield.Manager.Converters">

    <Page.Resources>
        <conv:ServiceRunningTextConverter x:Key="ServiceRunningText"/>
        <conv:OnlineBrushConverter x:Key="OnlineBrush"/>
        <conv:EventTypeGlyphConverter x:Key="EventGlyph"/>
        <conv:EventTypeBrushConverter x:Key="EventBrush"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StrToVis"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:DashboardViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Dashboard" Style="{StaticResource PageTitleText}" />

                <Border Grid.Column="1"
                        Style="{StaticResource StatusBadgeBorder}"
                        BorderBrush="{Binding IsServiceRunning, Converter={StaticResource OnlineBrush}}">
                    <TextBlock FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{Binding IsServiceRunning, Converter={StaticResource OnlineBrush}}"
                               Text="{Binding IsServiceRunning, Converter={StaticResource ServiceRunningText}}"/>
                </Border>

                <Button Grid.Column="3"
                        Content="Start"
                        Command="{Binding StartServiceCommand}"
                        Style="{StaticResource SuccessButton}" />

                <Button Grid.Column="5"
                        Content="Stop"
                        Command="{Binding StopServiceCommand}"
                        Style="{StaticResource DangerButton}" />

                <ProgressRing Grid.Column="7"
                              Width="18"
                              Height="18"
                              IsActive="{Binding IsLoading}"
                              VerticalAlignment="Center" />
            </Grid>

            <TextBlock Text="{Binding Error}" Style="{StaticResource ErrorText}" />

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource MetricCardRed}">
                    <StackPanel>
                        <TextBlock Text="Active bans" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding ActiveBansCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource MetricCardRed}">
                    <StackPanel>
                        <TextBlock Text="Failed attempts (10m)" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding FailedAttemptsLast10m}"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource MetricCardBlue}">
                    <StackPanel>
                        <TextBlock Text="Last banned IP" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding LastBannedIp}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource MetricCardGreen}">
                    <StackPanel>
                        <TextBlock Text="Last banned at" Style="{StaticResource MutedText}" />
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding LastBannedAtUtc, Converter={StaticResource LocalDtFmt}, ConverterParameter='dd-MMM-yy HH:mm:ss'}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Recent events" Style="{StaticResource SectionTitleText}" />

                    <Grid Style="{StaticResource TableHeaderGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="1" BorderBrush="{StaticResource SubtleLineBrush}" BorderThickness="0,0,1,0">
                            <TextBlock Text="Time" Style="{StaticResource TableHeaderText}" Margin="0,0,8,0"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="{StaticResource SubtleLineBrush}" BorderThickness="0,0,1,0">
                            <TextBlock Text="IP" Style="{StaticResource TableHeaderText}" Margin="0,0,8,0"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="Message" Style="{StaticResource TableHeaderText}" />
                    </Grid>

                    <ListView x:Name="DashboardEventsList"
                              ItemsSource="{Binding RecentEvents}"
                              MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Style="{StaticResource RowGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Glyph="{Binding Type, Converter={StaticResource EventGlyph}}"
                                              Foreground="{Binding Type, Converter={StaticResource EventBrush}}"
                                              FontSize="14"
                                              VerticalAlignment="Center" />

                                    <Border Grid.Column="1" BorderBrush="{StaticResource SubtleLineBrush}" BorderThickness="0,0,1,0">
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   Margin="0,0,8,0"
                                                   Text="{Binding TsUtc, Converter={StaticResource LocalDtFmt}, ConverterParameter='dd-MMM-yy HH:mm:ss'}"/>
                                    </Border>

                                    <Border Grid.Column="2" BorderBrush="{StaticResource SubtleLineBrush}" BorderThickness="0,0,1,0">
                                        <TextBlock Text="{Binding Ip}" Margin="0,0,8,0"/>
                                    </Border>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Message}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.Footer>
                            <StackPanel HorizontalAlignment="Center" Margin="0,6,0,6">
                                <ProgressRing Width="16"
                                              Height="16"
                                              IsActive="{Binding IsLoadingMoreRecentEvents}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource MutedText}"
                                           Text="{Binding RecentEventsFooterText}" />
                            </StackPanel>
                        </ListView.Footer>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10">
                    <TextBlock Text="Service runtime" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Current uptime" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding ServiceUptimeText}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Quick actions" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource CardBorder}">
                        <Grid RowSpacing="8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     Grid.Column="0"
                                     PlaceholderText="IP address"
                                     Text="{Binding UnbanIpInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Content="Unblock IP"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="26"
                                    Padding="8,2"
                                    Command="{Binding UnbanIpCommand}"
                                    Style="{StaticResource SuccessButton}" />

                            <TextBox Grid.Row="1"
                                     Grid.Column="0"
                                     PlaceholderText="IP or CIDR"
                                     Text="{Binding AllowlistIpInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Content="Allow IP"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="26"
                                    Padding="8,2"
                                    Command="{Binding AddIpToAllowlistCommand}"
                                    Style="{StaticResource SuccessButton}" />

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     PlaceholderText="IP address"
                                     Text="{Binding BlockIpInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Content="Block IP"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="26"
                                    Padding="8,2"
                                    Command="{Binding BlockIpCommand}"
                                    Style="{StaticResource DangerButton}" />

                            <TextBlock Text="{Binding QuickActionStatus}"
                                       Grid.Row="3"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource MutedText}"
                                       Visibility="{Binding QuickActionStatus, Converter={StaticResource StrToVis}}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
